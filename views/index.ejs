<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CRUD Alunos</title>

  <link rel="icon" href="/images/militar7.png" type="image/x-icon">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">

  <style>
    body,
    html {
      margin: 0;
      padding: 0;
      height: 100%;
    }

    .scrollable-table {
      max-height: 70vh;
      overflow-y: auto;
    }

    table.table td,
    table.table th {
      padding: 0.4rem 0.5rem;
      line-height: 1.2;
    }

    table.table tbody tr:hover {
      background-color: #deeff5;
      cursor: pointer;
    }

    .form-control::placeholder{
      opacity: 0.5;
    }
    input[type="date"]{
      opacity: 0.4;
    }

    .btn-indigo {
  background-color: #6f42c1;
  border-color: #6f42c1;
  color: #fff;
}

.btn-indigo:hover {
  background-color: #59339d;
  border-color: #59339d;
  color: #fff;
}

.btn-indigo:focus,
.btn-indigo:active {
  background-color: #4e2c8a;
  border-color: #4e2c8a;
  box-shadow: 0 0 0 .25rem rgba(111, 66, 193, .4);
}

.btn-pink {
  background: #d63384;
  border-color: #d63384;
  color: #fff;
}
.btn-pink:hover {
  background: #b82a6f;
  border-color: #b82a6f;
   color: #fff;
}

.btn-orange {
  background: #e7914b;
  border-color: #fd7e14;
  color: #fff;
}
.btn-orange:hover {
  background: #fd7e14;
  border-color: #fd7e14;
   color: #fff;
}
    @media (max-width: 576px) {
      .menu-content {
        flex-direction: column;
      }

      .menu-content .form-control,
      .menu-content button,
      .menu-content a {
        margin-bottom: 10px;
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <!-- Navbar com formulário e botões dentro do menu -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="#"></a>

      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
        <i class="bi bi-list fs-2"></i>
      </button>

      <div class="collapse navbar-collapse" id="menuPrincipal">
        <div class="menu-content d-flex flex-wrap align-items-center gap-2">

          <!-- Formulário de adicionar aluno -->
          <form action="/add" method="POST" class="row g-2 align-items-end w-100">
            <div class="col-md-2">
              <label for="nome" class="form-label"></label>
              <input type="text" pattern="[A-Za-zÀ-ÿ\s]+" title="Digite apenas letras" oninput="this.value = this.value.replace(/[^A-Za-zÀ-ÿ\s]/g, '')" id="nome" name="nome" class="form-control" placeholder="Digite o nome" required>
            </div>
            <div class="col-md-2">
              <label for="ra" class="form-label"></label>
              <input type="text" pattern="\d*" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')" id="ra" name="ra" class="form-control" placeholder="RA...9 dígitos" maxlength="9" required>
            </div>
            <div class="col-md-2">
              <label for="data_nascimento" class="form-label"></label>
              <input type="date" id="data_nascimento" name="data_nascimento" class="form-control" required>
            </div>
            <div class="col-md-2">
              <input type="tel" name="tel_responsavel_1" class="form-control form-control-sm"
                placeholder="ex.5511987654321" maxlength="15">
            </div>
            <div class="col-md-2">
              <input type="tel" name="tel_responsavel_2" class="form-control form-control-sm"
                placeholder="ex.5511987654321" maxlength="15">
            </div>
            <div class="col-md-1">
              <button type="submit" class="btn btn-success btn-sm w-100">
                <i class="bi bi-person-plus"></i> Adicionar
              </button>
            </div>
          </form>

          <!-- Botões de navegação -->
          <div class="d-flex flex-wrap gap-2 mt-2">
            <a href="/buscar" class="btn btn-indigo btn-sm">
              <i class="bi bi-person-walking"></i> Registrar Entrada Alunos
            </a>
            <a href="/entradas" class="btn btn-primary btn-sm">
              <i class="bi bi-list-ul"></i> Entradas do Dia
            </a>
            <a href="/entradas-mes" class="btn btn-pink btn-sm">
              <i class="bi bi-calendar-month"></i> Entradas do Mês
            </a>
            <a href="/relatorio_data" class="btn btn-orange btn-sm">
              <i class="bi bi-calendar-month"></i> Relatório por Data
            </a>
            <a href="/relatorio_atrasos" class="btn btn-info btn-sm">
              <i class="bi bi-stopwatch"></i></i> Contador de atrasos
            </a>
            <a href="/manual" class="btn btn-light">📘 Manual</a>
            <a href="/logout" class="btn btn-outline-dark btn-sm">
              <i class="bi bi-box-arrow-right"></i> Sair
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <div class="container mt-3">
    <h2 class="h6 text-center">CONTROLE DE PONTUALIDADE ESCOLAR - CPE</h2>

    <h2 class="mb-3 text-center">Lista de Alunos</h2>

    <div class="position-relative mb-3">
      <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-2 text-muted"></i>
      <input type="text" class="form-control form-control-sm ps-5" id="searchInput"
        placeholder="Buscar por Nome ou RA..." style="border: 1px solid rgb(0, 119, 255);">
    </div>


    <% if (typeof erro !=='undefined' && erro) { %>
      <div class="alert alert-danger">
        <%= erro %>
      </div>
      <% } %>

        <div class="scrollable-table mt-2">
          <table class="table table-striped table-bordered">
            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>RA</th>
                <th>Data de Nascimento</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% alunos.forEach(aluno=> { %>
                <tr>
                  <td>
                    <%= aluno.nome.toUpperCase() %>
                  </td>
                  <td>
                    <%= aluno.ra %>
                  </td>
                  <td>
                    <%= new Date(aluno.data_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                  </td>
                  <td>
                    <a href="/edit/<%= aluno.id %>" class="btn btn-sm btn-info">Visualizar/Editar</a>
                    <form action="/delete/<%= aluno.id %>" method="POST" style="display:inline;"
                      onsubmit="return confirm('Tem certeza que deseja excluir este aluno?');">
                      <button type="submit" class="btn btn-sm btn-light">Excluir</button>
                    </form>
                  </td>
                </tr>
                <% }); %>
            </tbody>
          </table>
        </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
      const input = this.value.toLowerCase();
      const rows = document.querySelectorAll("table tbody tr");

      rows.forEach(row => {
        const nome = row.children[0].textContent.toLowerCase();
        const ra = row.children[1].textContent.toLowerCase();
        row.style.display = (nome.includes(input) || ra.includes(input)) ? "" : "none";
      });
    });

    function imprimirTabela() {
      const conteudo = document.querySelector(".scrollable-table").innerHTML;
      const original = document.body.innerHTML;
      document.body.innerHTML = conteudo;
      window.print();
      document.body.innerHTML = original;
      location.reload();
    }
  </script>
</body>

</html>